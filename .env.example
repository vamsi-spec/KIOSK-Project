# ══════════════════════════════════════════════
# SUVIDHA — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────
DATABASE_URL=postgresql://suvidha:suvidha123@localhost:5432/suvidha_db

# ── AUTH SERVICE (Port 3001) ──────────────────
AUTH_PORT=3001
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=30m
BCRYPT_ROUNDS=10

# ── CORE SERVICE (Port 3002) ──────────────────
CORE_PORT=3002

# ── ADMIN SERVICE (Port 3003) ─────────────────
ADMIN_PORT=3003

# ── FRONTEND ──────────────────────────────────
VITE_API_BASE_URL=http://localhost/api
VITE_SOCKET_URL=http://localhost

# ── RAZORPAY (Phase 9) ────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── CLOUDINARY (Phase 10) ─────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMS GATEWAY (Phase 3) ─────────────────────
SMS_API_KEY=your_msg91_or_twilio_key
SMS_SENDER_ID=SUVIDHA

# ── KIOSK CONFIG ──────────────────────────────
KIOSK_ID=KIOSK_001
KIOSK_IDLE_TIMEOUT_MS=60000

# ── REDIS (Phase 3 — OTP storage) ─────────────
REDIS_URL=redis://localhost:6379

# ── NODE ENV ──────────────────────────────────
NODE_ENV=development